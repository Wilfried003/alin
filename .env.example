# Configuration des variables d'environnement pour les emails

# Serveur SMTP (ex: smtp.gmail.com pour Gmail)
SMTP_HOST=smtp.gmail.com

# Port SMTP (587 pour TLS, 465 pour SSL)
SMTP_PORT=587

# Utilisateur/Email SMTP
SMTP_USER=votre-email@gmail.com

# Mot de passe ou App Password
# Pour Gmail, générez une "App Password" (https://myaccount.google.com/apppasswords)
SMTP_PASS=votre-app-password

# Email destinataire pour les notifications
RECIPIENT_EMAIL=destination@example.com

